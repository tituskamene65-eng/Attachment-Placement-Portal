{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/students(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/companies(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/opportunities(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/applications(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/placements(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/stats",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ]
}
