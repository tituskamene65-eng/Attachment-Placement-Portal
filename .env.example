# ── Vercel Environment Variables ──────────────────────────────────────────────
#
# Copy this file to .env.local for local development.
# In production, set these in your Vercel project → Settings → Environment Variables.
#
# FRONTEND_URL
#   Set this on the API to restrict CORS to your deployed frontend domain.
#   Example: https://sapms.vercel.app
#   Leave unset to allow all origins (fine for demos, not recommended for prod).
#
# FRONTEND_URL=https://your-project.vercel.app
#
# REACT_APP_API_URL
#   Only needed if you deploy the API to a SEPARATE Vercel project from the frontend.
#   When both are in the same project (recommended), leave this unset — API routes
#   are served from the same domain, so no base URL is required.
#
# REACT_APP_API_URL=https://your-api.vercel.app
